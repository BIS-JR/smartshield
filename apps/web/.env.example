# Deixe em branco enquanto não tiver um Client ID real do Google OAuth;
# o botão "Continuar com Google" fica desabilitado e mostra um aviso.
VITE_GOOGLE_CLIENT_ID=

# Deixe em branco quando o frontend for servido pelo mesmo domínio da API
# (deploy "tudo junto" no Render). Preencha com a URL completa da API
# (terminando em /api) quando o frontend estiver num domínio separado,
# ex: https://smartshield-xxxx.onrender.com/api
VITE_API_URL=
