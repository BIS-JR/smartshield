PORT=4000
DATABASE_URL="postgresql://smartshield:smartshield@localhost:5432/smartshield?schema=public"

JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-acesso
JWT_REFRESH_SECRET=troque-por-um-segredo-forte-de-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Deixe em branco enquanto não tiver credenciais reais: login Google fica
# desativado e o código OTP é apenas logado no console do servidor.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Deixe em branco para simular o envio de e-mail (o código aparece no console
# do servidor). Preencha com um provedor real (ex: Resend, SendGrid, Gmail
# SMTP) para enviar e-mails de verdade.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SmartShield <no-reply@smartshield.exemplo.com>"

DECISION_ENGINE=simulated

WEB_ORIGIN=http://localhost:5173

# Origens extras liberadas no CORS, separadas por vírgula. Use quando o
# frontend roda num domínio diferente da API (ex: frontend na Vercel,
# API aqui no Render): EXTRA_ALLOWED_ORIGINS=https://smartshield.vercel.app
EXTRA_ALLOWED_ORIGINS=
